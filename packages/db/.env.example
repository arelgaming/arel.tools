# Database (Neon) — app_role (guild queries, RLS enforced)
DATABASE_URL="postgresql://app_role:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"

# Database (Neon) — db_manager_role (DDL, direct — Prisma Migrate only)
DATABASE_DIRECT_URL="postgresql://db_manager_role:<password>@<endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"

# Shadow DB — neondb_owner, needs full DDL (DROP/CREATE schema) for prisma migrate
SHADOW_DATABASE_URL="postgresql://neondb_owner:<password>@<shadow-endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"
