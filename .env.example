# Database (Neon) — app_role (guild queries, RLS enforced)
DATABASE_URL="postgresql://app_role:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"

# Database (Neon) — db_manager_role (DDL, direct — Prisma Migrate only)
DATABASE_DIRECT_URL="postgresql://db_manager_role:<password>@<endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"
# Shadow DB uses neondb_owner — needs full DDL (DROP/CREATE schema) to reset state between runs
SHADOW_DATABASE_URL="postgresql://neondb_owner:<password>@<shadow-endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"

# Database (Neon) — admin_role (admin procedures only, BYPASSRLS)
ADMIN_DATABASE_URL="postgresql://admin_role:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"
ADMIN_DATABASE_DIRECT_URL="postgresql://admin_role:<password>@<endpoint>.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""

# NextAuth
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Flagsmith
FLAGSMITH_SERVER_KEY=""

# Inngest
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
